class Solution {
    public int[] shuffle(int[] nums, int n) {
        int[] ans=new int[n+n];
        int x=0;
        int y=n;
        for(int i=0;i<n+n;i++){
            if(i%2==0){
                ans[i]=nums[x];
                x++;
            }
            else{
                ans[i]=nums[y];
                y++;
            }
        }
        return ans;
    }
}