Brute force method: create a new matrix and copy the elements in the rotated position, then copy back to the original matrix.
class Solution {
    public void rotate(int[][] matrix) {
        int n = matrix.length;
        int[][] ans=new int[n][n];
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < n; j++) {
                ans[j][n-1-i] = matrix[i][j];
            }
        }
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < n; j++) {
                matrix[i][j] = ans[i][j];
            }
        }
    }
}
Optimised method:
class Solution {
    public void rotate(int[][] matrix) {
        int n = matrix.length;
        int[][] ans=new int[n][n];
        //transpose
        for (int i = 0; i < n; i++) {
            for (int j = i; j < n; j++) {
                int temp=matrix[i][j];
                matrix[i][j]=matrix[j][i];
                matrix[j][i]=temp;
            }
        }
        //reverse
        for (int i = 0; i < n; i++) {
            int left=0,right=n-1;
            while(left<right){
                int temp=matrix[i][left];
                matrix[i][left]=matrix[i][right];
                matrix[i][right]=temp;
                left++;
                right--;
            }
        }
    }
}
